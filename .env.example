GREENHOUSE_BOARD_TOKENS=
ASHBY_JOB_BOARD_NAMES=
LEVER_SITE_NAMES=
LEVER_EU_SITE_NAMES=
RECRUITEE_COMPANY_SLUGS=
JOB_VERIFICATION_MAX_BATCH=4
JOB_VERIFICATION_STALE_HOURS=24
JOB_VERIFICATION_TIMEOUT_SECONDS=6
JOB_INGESTION_SKILLS=python,react,javascript,typescript,java,backend,frontend,devops,data engineer,SQL Server,PL/SQL,SSIS,SSRS,Power BI,ETL,Business Intelligence,data warehouse,T-SQL
JOB_INGESTION_LOCATIONS=Madrid,Barcelona,Valencia,Toda España
JOB_INGESTION_SOURCES=public_sources,adzuna,jobspy,jsearch
JOB_INGESTION_MAX_ADZUNA_SEEDS=4
# Máximo de ofertas que aporta UNA sola fuente/board por ingesta, para que una
# empresa con muchas vacantes (p. ej. un board grande de Greenhouse) no domine
# el índice. Usa varios tokens en GREENHOUSE/ASHBY/LEVER/RECRUITEE para diversificar. 0 = sin límite.
JOB_INGESTION_MAX_OFFERS_PER_SOURCE=25
# JobSpy (Indeed scraping — gratis, sin API key)
JOBSPY_ENABLED=false
# JSearch via RapidAPI — agrega LinkedIn/Indeed/Glassdoor (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
JSEARCH_API_KEY=

# ── Schedulers de background ──────────────────────────────────────────────────
# Frecuencia de ingesta automática de ofertas (horas).
# Para demo/TFM: usar 8760 (1 año) para deshabilitar el scheduler
# y lanzar ingestas manualmente desde el panel de Admin.
JOB_INGESTION_INTERVAL_HOURS=12

# Frecuencia de procesado de alertas de empleo (horas).
# Para demo/TFM: usar 8760 para deshabilitar emails automáticos a usuarios.
ALERTS_INTERVAL_HOURS=24

# ── ElevenLabs TTS (entrevista por voz) ──────────────────────────────────────
# Por defecto la voz del entrevistador la pone el navegador (Web Speech API, coste 0).
# ElevenLabs es opcional (de pago): solo se usa si INTERVIEW_ELEVENLABS_ENABLED=true Y hay API key.
INTERVIEW_ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Sentry error tracking (opcional) ─────────────────────────────────────────
# Obtén el DSN en https://sentry.io → Settings → Projects → Client Keys
# Dejar vacío para desactivar. No tiene coste en el plan gratuito.
SENTRY_DSN=
# Variable frontend (prefijo REACT_APP_ requerido por CRA)
REACT_APP_SENTRY_DSN=
